[global]
    workgroup = LAB
    realm = LAB.LOCAL

    security = ADS
    server role = member server
    kerberos method = secrets and keytab

    winbind use default domain = no
    winbind offline logon = yes
    winbind refresh tickets = yes
    winbind enum users = no
    winbind enum groups = no

    idmap config * : backend = tdb
    idmap config * : range = 10000-99999

    idmap config LAB : backend = rid
    idmap config LAB : range = 2000000-2999999

    template shell = /bin/bash
    template homedir = /home/%U@%D

    obey pam restrictions = yes
    pam password change = yes

    logging = file
    log file = /var/log/samba/log.%m
    max log size = 1000

    map to guest = bad user


[Public]
    comment = Company Public Share
    path = /company/public
    browseable = yes
    read only = no
    valid users = @LAB\gg_allemployees


[HR]
    comment = HR Department Share
    path = /company/hr
    browseable = yes
    read only = no
    valid users = @LAB\gg_hr @LAB\gg_management


[IT]
    comment = IT Department Share
    path = /company/it
    browseable = yes
    read only = no
    valid users = @LAB\gg_it


[MNGT]
    comment = Management Share
    path = /company/mngt
    browseable = yes
    read only = no
    valid users = @LAB\gg_management
